{
  "name": "manoshop-lite",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "node scripts/dev.js",
    "setup:start": "node scripts/setup-and-start.js",
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev",
    "build": "npm --workspace client run build",
    "start": "npm --workspace server run start",
    "seed": "npm --workspace server run seed",
    "seed:digital": "node .\\database\\seed-digital-products.js",
    "import:savings": "node .\\scripts\\import-ledger-lane-data.js",
    "test:admin-flow": "powershell -ExecutionPolicy Bypass -File .\\scripts\\test-admin-flow.ps1"
  }
}
