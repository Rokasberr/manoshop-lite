PORT=5000
# Local MongoDB example:
MONGO_URI=mongodb://127.0.0.1:27017/manoshop
# MongoDB Atlas example:
# MONGO_URI=mongodb+srv://<dbUser>:<dbPassword>@<clusterName>.<hash>.mongodb.net/manoshop?retryWrites=true&w=majority&appName=Cluster0
JWT_SECRET=super_secret_key_here
# Put the primary frontend URL first.
# Additional origins can be comma-separated, including preview or wildcard hosts.
# Example: CLIENT_URL=https://www.manoshop.lt,https://manoshop.vercel.app,https://*.vercel.app
CLIENT_URL=http://localhost:5173,http://127.0.0.1:5173
COMPANY_NAME=ManoShop Lite
NODE_ENV=development
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
